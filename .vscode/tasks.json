{
  "version": "2.0.0",
  "tasks": [
    // ==================== DEVELOPMENT TASKS ====================
    {
      "label": "Dev: Start Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Dev: Build",
      "type": "shell",
      "command": "npm run build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Dev: Start Production Server",
      "type": "shell",
      "command": "npm run start",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    // ==================== TEST TASKS ====================
    {
      "label": "Test: Run Tests",
      "type": "shell",
      "command": "npm run test -- --run",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Test: Watch Mode",
      "type": "shell",
      "command": "npx vitest",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Test: UI Mode",
      "type": "shell",
      "command": "npx vitest --ui",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Test: Coverage",
      "type": "shell",
      "command": "npx vitest run --coverage",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    // ==================== LINT TASKS ====================
    {
      "label": "Lint: ESLint",
      "type": "shell",
      "command": "npm run lint",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "Lint: Fix ESLint Issues",
      "type": "shell",
      "command": "npm run lint -- --fix",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint: TypeScript Check",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "Lint: Format (Prettier)",
      "type": "shell",
      "command": "npx prettier --write .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint: Check Formatting",
      "type": "shell",
      "command": "npx prettier --check .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    // ==================== DOCKER TASKS ====================
    {
      "label": "Docker: Build and Run",
      "type": "shell",
      "command": "docker compose up -d --build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Docker: Stop",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: View Logs",
      "type": "shell",
      "command": "docker compose logs -f",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: Rebuild Frontend",
      "type": "shell",
      "command": "docker compose up -d --build --no-deps frontend",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: Check Health",
      "type": "shell",
      "command": "echo '🏥 Health Check...' && curl -I http://localhost:3000",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    // ==================== SECURITY TASKS ====================
    {
      "label": "Security: npm audit",
      "type": "shell",
      "command": "npm audit --audit-level=moderate",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "showReuseMessage": false
      }
    },
    // ==================== GITHUB ACTIONS TASKS ====================
    {
      "label": "Lint GitHub Actions Workflows",
      "type": "shell",
      "command": "actionlint .github/workflows/*.yml",
      "problemMatcher": {
        "owner": "actionlint",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+): (.+?) \\[(.+?)\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4,
          "code": 5
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    // ==================== COMPOSITE QUALITY CHECKS ====================
    {
      "label": "Full Quality Check",
      "dependsOn": [
        "Lint: ESLint",
        "Lint: TypeScript Check",
        "Lint: Check Formatting",
        "Test: Coverage",
        "Security: npm audit",
        "Lint GitHub Actions Workflows"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Pre-Push Quality Gate",
      "dependsOn": [
        "Lint: ESLint",
        "Lint: TypeScript Check",
        "Test: Run Tests",
        "Docker: Build and Run"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "Fix All Formatting",
      "dependsOn": ["Lint: Fix ESLint Issues", "Lint: Format (Prettier)"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    // ==================== UTILITY TASKS ====================
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
