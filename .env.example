# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
#
# All secrets follow the TEAMSHUFFLER_ prefix convention.
# In production, secrets are managed via Infisical.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
TEAMSHUFFLER_APP_URL=http://localhost:3000

# ── Future Platform ───────────────────────────────────────────────────────────
# Uncomment when backend/database support is added (see Future Platform issues)
#
# TEAMSHUFFLER_POSTGRES_USER=teamshuffler
# TEAMSHUFFLER_POSTGRES_PASSWORD=changeme
# TEAMSHUFFLER_POSTGRES_DB=teamshuffler
# TEAMSHUFFLER_POSTGRES_HOST=db
# TEAMSHUFFLER_POSTGRES_PORT=5432
